# EmailJS configuration — https://dashboard.emailjs.com/
# Copy this file to `.env.local` and fill in your credentials.
# The contact form gracefully falls back to a mailto: link if these are absent.
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key

# Public site URL (used for SEO / sitemap / Open Graph)
NEXT_PUBLIC_SITE_URL=https://divyatripathi.dev
